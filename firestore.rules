rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChatOwner(chatId) {
      return isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kavinila1577@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('nativeLanguage' in data) || data.nativeLanguage is string);
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'type', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['general', 'tutor'] &&
             (!('language' in data) || data.language is string) &&
             (!('title' in data) || data.title is string) &&
             (!('lastMessage' in data) || data.lastMessage is string) &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'role', 'content', 'timestamp']) &&
             data.chatId is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string &&
             data.content.size() < 10000 &&
             data.timestamp is timestamp &&
             (!('isPronunciationFeedback' in data) || data.isPronunciationFeedback is bool) &&
             (!('feedback' in data) || data.feedback is map);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidChat(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read: if isChatOwner(chatId) || isAdmin();
        allow create: if isChatOwner(chatId) && isValidMessage(request.resource.data);
        allow delete: if isChatOwner(chatId) || isAdmin();
      }
    }
  }
}
